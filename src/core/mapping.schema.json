{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Export Mapping Config",
  "type": "object",
  "required": ["formatKey", "header", "columns"],
  "properties": {
    "formatKey": {
      "type": "string",
      "enum": ["v7e_strict", "v7e_legacy", "modules_generic"]
    },
    "header": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key", "label"],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "headerAliases": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
